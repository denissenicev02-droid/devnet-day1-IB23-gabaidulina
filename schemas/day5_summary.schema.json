{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Day5 Summary Schema",
  "version": "5.0",
  "type": "object",
  "required": ["schema_version", "student", "yang", "webex", "pt", "bonus", "validation_passed"],
  "properties": {
    "schema_version": { "type": "string", "const": "5.0" },
    "student": {
      "type": "object",
      "required": ["token", "token_hash8", "name", "group"],
      "properties": {
        "token":      { "type": "string" },
        "token_hash8":{ "type": "string", "minLength": 8, "maxLength": 8 },
        "name":       { "type": "string" },
        "group":      { "type": "string" }
      }
    },
    "yang": {
      "type": "object",
      "required": ["ok", "evidence_sha"],
      "properties": {
        "ok":           { "type": "boolean" },
        "evidence_sha": { "type": ["string", "null"] }
      }
    },
    "webex": {
      "type": "object",
      "required": ["ok", "room_title_contains_hash8", "evidence_sha"],
      "properties": {
        "ok":                        { "type": "boolean" },
        "room_title_contains_hash8": { "type": "boolean" },
        "evidence_sha":              { "type": ["string", "null"] }
      }
    },
    "pt": {
      "type": "object",
      "required": ["ok", "empty_ticket_seen", "evidence_sha"],
      "properties": {
        "ok":                 { "type": "boolean" },
        "empty_ticket_seen":  { "type": "boolean" },
        "evidence_sha":       { "type": ["string", "null"] }
      }
    },
    "bonus": {
      "type": "object",
      "required": ["optional_ok", "evidence_sha"],
      "properties": {
        "optional_ok":  { "type": "boolean" },
        "evidence_sha": { "type": ["string", "null"] }
      }
    },
    "validation_passed": { "type": "boolean" }
  }
}